# Copy this file to .env and replace the database placeholders.
# Do not commit .env; it contains credentials.

# Express server
NODE_ENV=development
PORT=3000
# Keep this at 0 locally. Set the exact number of trusted proxies in production.
TRUST_PROXY=0

# MySQL connection. Use a database account limited to this application's tables.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=hampshire_hotel
DB_USER=hampshire_app
DB_PASSWORD=replace-with-a-strong-password
DB_SSL=false
DB_CONNECTION_LIMIT=5

# Contact form abuse protection
CONTACT_RATE_LIMIT_WINDOW_MINUTES=15
CONTACT_RATE_LIMIT_MAX=5
